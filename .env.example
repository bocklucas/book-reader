# LLM Configuration
# Base URL for the OpenAI-compatible LLM server (e.g., llama.cpp)
LLAMACPP_BASE_URL=http://localhost:8080/v1
# Optional API key for the LLM server (leave blank if unused)
LLAMACPP_API_KEY=
# Model identifier for the small/fast tier (front-matter detection, character analysis)
LLAMACPP_SMALL_MODEL=qwen3-4b-instruct
# Model identifier for the large/quality tier (script generation, reasoning)
LLAMACPP_LARGE_MODEL=qwen3-35b-instruct

# Optional: URL of a model-swap helper that can hot-swap models on the LLM server
MODEL_SWAP_URL=
# Optional: keep both models resident in memory (true/false). Defaults to false.
KEEP_MODELS_LOADED=false

# TTS Configuration
# Base URL for the OmniVoice-FastAPI server
OMNIVOICE_BASE_URL=http://localhost:8880/v1
# Speech speed multiplier (e.g., 1.0 for normal, 0.9 for slightly slower)
OMNIVOICE_SPEED=1.0

# Other Configuration
# Anthropic API Key (if using Anthropic instead of local LLM in some parts)
# ANTHROPIC_API_KEY=your_api_key_here
